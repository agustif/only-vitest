{
  "name": "@agustif/only-vitest",
  "version": "0.1.0",
  "description": "Silently redirect bare bun test to Vitest and enforce Vitest as the approved repo test runner",
  "type": "module",
  "license": "MIT",
  "bin": {
    "only-vitest": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agustif/only-vitest.git"
  },
  "bugs": {
    "url": "https://github.com/agustif/only-vitest/issues"
  },
  "homepage": "https://github.com/agustif/only-vitest#readme",
  "keywords": [
    "bun",
    "vitest",
    "test",
    "shim",
    "policy"
  ],
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "check": "bunx tsc -p tsconfig.json --pretty false",
    "lint": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "test": "bunx vitest run",
    "smoke": "node dist/cli.js --help"
  },
  "dependencies": {
    "@effect/cli": "0.73.2",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "@effect/printer": "0.47.0",
    "@effect/printer-ansi": "0.47.0",
    "@effect/typeclass": "0.38.0",
    "effect": "3.19.19"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "25.4.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
